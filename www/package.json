{
  "name": "www",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "generate-api": "typedoc --plugin typedoc-plugin-markdown --entryPoints ../src/index.ts --out ./docs/API --tsconfig ../tsconfig.json --readme none --mergeReadme false --entryFileName index.md --modulesFileName index.md --sanitizeComments true --cleanOutputDir true --includeHierarchySummary false   --categorizeByGroup false --outputFileStrategy members",
    "postgenerate-api": "bash ./scripts/postTypedoc.sh",
    "build": "npm run generate-api && docusaurus build",
    "start": "npm run generate-api && docusaurus start",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "version": "docusaurus docs:version",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@docusaurus/core": "^3.0.0",
    "@docusaurus/preset-classic": "^3.0.0",
    "@mdx-js/react": "^3.0.0",
    "clsx": "^2.0.0",
    "prism-react-renderer": "^2.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet": "^6.1.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^3.0.0",
    "@docusaurus/tsconfig": "^3.0.0",
    "@types/node": "^20.0.0",
    "docusaurus-plugin-typedoc": "^1.4.1",
    "typedoc": "^0.28.16",
    "typedoc-plugin-markdown": "^4.9.0",
    "typescript": "~5.7.0"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=18.0"
  }
}
